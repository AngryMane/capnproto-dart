# ── Dart ──────────────────────────────────────────────────────────────────────

# Tooling cache (pub get / dart analyze artifacts).
# packages/capnproto_dart and packages/capnproto_dart_rpc each have their own
# .gitignore (generated by dart pub) that also covers .dart_tool/ and
# pubspec.lock; this rule catches the remaining Dart packages under tools/ and
# sample/.
.dart_tool/

# Legacy package-resolution file (superseded by .dart_tool)
.packages

# Generated build output
build/

# pubspec.lock for in-tree tool/plugin packages.
# Sample application packages (sample/**/client/) intentionally commit their
# lock files for reproducible builds, so we only ignore the tool here.
tools/*/pubspec.lock

# ── Rust ──────────────────────────────────────────────────────────────────────

# Compiled output — can reach several GB and must not be committed.
target/

# Cargo.lock is intentionally tracked for the sample server binaries (executables
# should pin their dependency graph for reproducible builds).

# ── Editor / IDE ──────────────────────────────────────────────────────────────

# JetBrains IDEs (IntelliJ, CLion, RustRover, …)
.idea/

# VS Code workspace settings.
# Uncomment if your team does not share launch / extension configs:
# .vscode/

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# ── OS ────────────────────────────────────────────────────────────────────────

.DS_Store
.AppleDouble
Thumbs.db
Desktop.ini

# ── Logs / Temp ───────────────────────────────────────────────────────────────

*.log
